{
  "name": "vitepress-blogs",
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build:github": "vitepress build docs --base '/vitepress-blogs/'",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint:eslint": "eslint . --ext .ts,.js,.vue --fix",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@chunge16/vitepress-blogs-theme": "^0.5.6",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@iconify/tailwind4": "^1.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "markdown-it": "^14.1.0",
    "tailwindcss": "^4.2.2",
    "vitepress": "^1.6.4",
    "vue": "^3.5.31",
    "vue-eslint-parser": "^10.4.0"
  },
  "lint-staged": {
    "*.{cjs,js,ts,vue}": [
      "npm run lint:eslint"
    ]
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@algolia/client-search",
        "search-insights"
      ]
    }
  }
}
